---
import Layout from '../layouts/Layout.astro'
import TitleBox from '../components/TitleBox.astro'
import Button from '../components/Button.astro'
---

<Layout title="404 — Not found | glncy" description="This page doesn't exist.">
  <div class="flex h-screen w-screen flex-col items-center justify-center gap-6 px-4">
    <TitleBox title="404" subtitle="This page wandered off. Let's get you back." />
    <div class="flex flex-wrap items-center justify-center gap-3">
      <Button href="/" icon="ph:house">Home</Button>
      <Button href="/posts" icon="ph:arrow-right">Posts</Button>
      <Button href="/contact" icon="ph:paper-plane-tilt">Contact</Button>
    </div>
  </div>
</Layout>
