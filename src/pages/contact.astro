---
import Layout from '../layouts/Layout.astro'
import TitleBox from '../components/TitleBox.astro'
import settings from '../data/settings.json'

const { email, linkedin, messenger } = settings.contact
---

<Layout title="Contact | glncy">
  <div class="flex h-screen w-screen flex-col items-center justify-center">
    <TitleBox title="Contact" subtitle={settings.pages.contactSubtitle} />
    <div class="mt-3 flex max-w-xs flex-wrap justify-center gap-3 md:max-w-2xl">
      <a class="cta glass" href={`mailto:${email}`}>
        <i class="devicon-google-plain"></i> {email}
      </a>
      <a class="cta glass" href={linkedin} target="_blank" rel="noopener">
        <i class="devicon-linkedin-plain"></i> LinkedIn
      </a>
      <a class="cta glass" href={messenger} target="_blank" rel="noopener">
        Messenger
      </a>
    </div>
  </div>
</Layout>
