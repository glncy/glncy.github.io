---
import Layout from '../layouts/Layout.astro'
import TitleBox from '../components/TitleBox.astro'
import PostBrowser from '../components/PostBrowser.astro'
import { getCollection } from 'astro:content'

const blog = (await getCollection('blog')).map((p) => ({
  href: `/blog/${p.id}`,
  type: 'Blog' as const,
  title: p.data.title,
  date: p.data.date,
  description: p.data.description,
  thumbnail: p.data.thumbnail,
  tags: p.data.tags,
}))
const til = (await getCollection('til')).map((p) => ({
  href: `/til/${p.id}`,
  type: 'TIL' as const,
  title: p.data.title,
  date: p.data.date,
  description: p.data.description,
  thumbnail: p.data.thumbnail,
  tags: p.data.tags,
}))
const posts = [...blog, ...til].sort((a, b) => b.date.getTime() - a.date.getTime())
---

<Layout title="Posts | glncy" description="Essays, build logs, and quick notes on web & mobile development, design, and what I'm learning.">
  <div class="pb-40">
    <div class="relative flex h-screen w-full flex-col items-center justify-center">
      <TitleBox title="Posts" subtitle="Essays, build logs, and quick notes on what I'm learning." />
      <div class="absolute text-sm text-gray-200 opacity-80" style="margin-top:38vh;">Scroll Down</div>
      <div class="down-arrow absolute"></div>
    </div>

    <div class="mx-auto max-w-4xl px-4">
      <PostBrowser posts={posts} layout="grid" showTypeFilter emptyText="No posts yet." />
    </div>
  </div>
</Layout>
