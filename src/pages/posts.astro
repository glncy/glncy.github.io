---
import Layout from '../layouts/Layout.astro'
import TitleBox from '../components/TitleBox.astro'
import PostBrowser from '../components/PostBrowser.astro'
import { Icon } from 'astro-icon/components'
import { getCollection } from 'astro:content'
import settings from '../data/settings.json'

const blog = (await getCollection('blogs', ({ data }) => !data.draft && !data.hidden)).map((p) => ({
  href: `/blogs/${p.id}`,
  type: 'Blog' as const,
  title: p.data.title,
  date: p.data.date,
  description: p.data.description,
  thumbnail: p.data.thumbnail,
  tags: p.data.tags,
}))
const til = (await getCollection('tils', ({ data }) => !data.draft && !data.hidden)).map((p) => ({
  href: `/tils/${p.id}`,
  type: 'TIL' as const,
  title: p.data.title,
  date: p.data.date,
  description: p.data.description,
  thumbnail: p.data.thumbnail,
  tags: p.data.tags,
}))
const posts = [...blog, ...til].sort((a, b) => b.date.getTime() - a.date.getTime())
---

<Layout title="Posts | glncy" description="Essays, build logs, and quick notes on web & mobile development, design, and what I'm learning.">
  <div class="pb-40">
    <div class="relative flex h-screen w-full flex-col items-center justify-center">
      <TitleBox title="Posts" subtitle={settings.pages.postsSubtitle} />
      <div class="absolute text-sm text-gray-200 opacity-80" style="margin-top:38vh;">Scroll Down</div>
      <div class="down-arrow absolute"></div>
    </div>

    <div class="mx-auto max-w-4xl px-4">
      <PostBrowser posts={posts} layout="grid" showTypeFilter emptyText="No posts yet." />

      <div class="mt-16 flex flex-col items-center text-center">
        <div class="font-heading text-3xl text-gray-100">Like what you read?</div>
        <p class="mt-2 text-gray-300">Let's build something together.</p>
        <a href="/contact" class="cta panel mt-5">
          Get in touch <Icon class="arrow" name="ph:arrow-right" />
        </a>
      </div>
    </div>
  </div>
</Layout>
