---
import Layout from '../../layouts/Layout.astro'
import TitleBox from '../../components/TitleBox.astro'
import PostBrowser from '../../components/PostBrowser.astro'
import { getCollection } from 'astro:content'
import settings from '../../data/settings.json'

const posts = (await getCollection('til', ({ data }) => !data.draft && !data.hidden))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .map((p) => ({
    href: `/til/${p.id}`,
    type: 'TIL' as const,
    title: p.data.title,
    date: p.data.date,
    description: p.data.description,
    thumbnail: p.data.thumbnail,
    tags: p.data.tags,
  }))
---

<Layout title="TIL | glncy" description="Today I Learned — short notes and quick wins from day-to-day development.">
  <div class="pb-40">
    <div class="relative flex h-screen w-full flex-col items-center justify-center">
      <TitleBox title="TIL" subtitle={settings.pages.tilSubtitle} />
      <div class="absolute text-sm text-gray-200 opacity-80" style="margin-top:38vh;">Scroll Down</div>
      <div class="down-arrow absolute"></div>
    </div>

    <div class="mx-auto max-w-4xl px-4">
      <PostBrowser posts={posts} layout="list" emptyText="No TILs yet." />
    </div>
  </div>
</Layout>
