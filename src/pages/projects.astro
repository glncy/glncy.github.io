---
import Layout from '../layouts/Layout.astro'
import TitleBox from '../components/TitleBox.astro'
import Projects from '../components/sections/Projects.astro'
import { Icon } from 'astro-icon/components'
import settings from '../data/settings.json'

const handles = settings.handles ?? []
---

<Layout title="Projects | glncy">
  <div class="pb-40">
    <div class="relative flex h-dvh w-full flex-col items-center justify-center">
      <TitleBox title="Projects" subtitle={settings.pages.projectsSubtitle}>
        {handles.length > 0 && (
          <div class="handles">
            {handles.map((h, i) => (
              <>
                {i > 0 && <span class="handle-dot">·</span>}
                <a class="handle" href={h.url} target="_blank" rel="noopener noreferrer">
                  <Icon name={h.icon} /> {h.handle}
                </a>
              </>
            ))}
          </div>
        )}
      </TitleBox>
      <div class="absolute text-sm text-gray-200 opacity-80" style="margin-top:38vh;">
        Scroll Down
      </div>
      <div class="down-arrow absolute"></div>
    </div>

    <div class="mx-auto max-w-6xl px-4">
      <Projects />

      <div class="mt-10 flex justify-center">
        <a href="/posts" class="cta glass">Read my posts <Icon class="arrow" name="ph:arrow-right" /></a>
      </div>
    </div>
  </div>
</Layout>

<style>
  .handles {
    margin-top: 1rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    text-shadow: 0 1px 10px rgba(0, 0, 0, 0.85), 0 1px 3px rgba(0, 0, 0, 0.7);
  }
  .handle {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: #e5e7eb;
    font-size: 0.95rem;
    transition: color 0.15s ease, transform 0.15s ease;
  }
  .handle:hover { color: #fff; transform: translateY(-1px); }
  .handle :global(svg) { width: 1.05rem; height: 1.05rem; }
  .handle-dot { color: #9ca3af; user-select: none; }
</style>
