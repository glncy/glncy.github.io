---
import '../styles/global.css'
import { ClientRouter } from 'astro:transitions'
import Background from '../components/Background.astro'
import Header from '../components/Header.astro'
import { Icon } from 'astro-icon/components'
import settings from '../data/settings.json'

interface Props {
  title?: string
  description?: string
  image?: string
  type?: 'website' | 'article'
  jsonLd?: Record<string, unknown> | Record<string, unknown>[]
}

const {
  title = settings.siteTitle,
  description = settings.siteDescription,
  image = '/assets/profile-picture.png',
  type = 'website',
  jsonLd,
} = Astro.props

const ga = settings.analyticsId
const canonical = new URL(Astro.url.pathname, Astro.site).href
const ogImage = new URL(image, Astro.site).href
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- iOS 26 samples this to tint Safari's UI bars; keep them dark to blend
         with the area behind the bottom toolbar (which fixed content can't reach). -->
    <meta name="theme-color" content="#000000" />
    <meta name="description" content={description} />
    <meta name="format-detection" content="telephone=no" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={settings.siteTitle} />
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- RSS autodiscovery -->
    <link rel="alternate" type="application/rss+xml" title="glncy — Posts" href="/rss.xml" />

    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    <!-- SPA-style navigation so the background video + music player keep playing. -->
    <ClientRouter />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap"
      rel="stylesheet"
    />
    <!-- Devicon (skill icons) -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/devicons/devicon@v2.16.0/devicon.min.css"
    />

    <!-- Google Analytics -->
    {ga && (
      <>
        <script
          is:inline
          async
          src={`https://www.googletagmanager.com/gtag/js?id=${ga}`}
        ></script>
        <script is:inline define:vars={{ ga }}>
          window.dataLayer = window.dataLayer || []
          function gtag() { dataLayer.push(arguments) }
          gtag('js', new Date())
          gtag('config', ga)
        </script>
      </>
    )}
  </head>
  <body class="overflow-x-hidden">
    <Background />

    <Header />

    <!-- NOTE: do NOT put transition:animate / view-transition-name on <main>.
         It isolates <main> into its own snapshot layer, which breaks
         backdrop-filter on descendants (the frosted hero box) because the
         fixed Background lives outside <main>. -->
    <main class="relative z-10">
      <slot />
    </main>

    <!-- Site-wide image lightbox (tap to open, tap anywhere to close).
         transition:persist keeps it (and its bound handlers) alive across
         ClientRouter navigations — otherwise it'd break until a refresh. -->
    <div id="lightbox" class="lightbox" aria-hidden="true" transition:persist="lightbox">
      <button id="lightbox-close" class="lightbox-close" type="button" aria-label="Close">&times;</button>
      <img id="lightbox-img" alt="" />
      <div class="lightbox-toolbar">
        <button id="lightbox-prev" class="lb-tbtn lb-nav" type="button" aria-label="Previous" hidden>&#8249;</button>
        <button id="lightbox-zoomout" class="lb-tbtn lb-zoom" type="button" aria-label="Zoom out"><Icon name="ph:magnifying-glass-minus" /></button>
        <button id="lightbox-zoomin" class="lb-tbtn lb-zoom" type="button" aria-label="Zoom in"><Icon name="ph:magnifying-glass-plus" /></button>
        <button id="lightbox-next" class="lb-tbtn lb-nav" type="button" aria-label="Next" hidden>&#8250;</button>
      </div>
    </div>

    <script is:inline>
      function initLightbox() {
        const box = document.getElementById('lightbox')
        const lbImg = document.getElementById('lightbox-img')
        const closeBtn = document.getElementById('lightbox-close')
        const prevBtn = document.getElementById('lightbox-prev')
        const nextBtn = document.getElementById('lightbox-next')
        const zoomInBtn = document.getElementById('lightbox-zoomin')
        const zoomOutBtn = document.getElementById('lightbox-zoomout')
        if (!box || !lbImg) return

        // Mark eligible images each page (skip icons/avatars, linked images, self).
        document.querySelectorAll('img').forEach((el) => {
          if (el === lbImg || el.dataset.zoomChecked) return
          el.dataset.zoomChecked = '1'
          if (el.closest('a')) return
          const w = el.clientWidth || el.naturalWidth || 0
          if (w && w < 64) return
          el.classList.add('zoomable')
          el.style.cursor = 'pointer'
        })

        if (window.__lightboxBound) return
        window.__lightboxBound = true

        let scale = 1, tx = 0, ty = 0
        let gallery = [], idx = -1
        const pts = new Map()
        let startDist = 0, startScale = 1, panStart = null, moved = false, swipeStartX = 0
        const clamp = (v, a, b) => Math.min(b, Math.max(a, v))
        const apply = () => {
          lbImg.style.transform = 'translate(' + tx + 'px,' + ty + 'px) scale(' + scale + ')'
          box.classList.toggle('zoomed', scale > 1)
        }
        const reset = () => { scale = 1; tx = 0; ty = 0; apply() }
        const showNav = () => {
          const multi = gallery.length > 1
          if (prevBtn) prevBtn.hidden = !multi
          if (nextBtn) nextBtn.hidden = !multi
        }
        const showAt = (i) => {
          if (!gallery.length) return
          idx = (i + gallery.length) % gallery.length
          const el = gallery[idx]
          lbImg.src = el.currentSrc || el.src
          lbImg.alt = el.alt || ''
          reset()
        }
        const open = (el) => {
          gallery = [...document.querySelectorAll('img.zoomable')]
          idx = gallery.indexOf(el)
          showNav()
          showAt(idx < 0 ? 0 : idx)
          box.classList.add('open'); box.setAttribute('aria-hidden', 'false')
          document.body.style.overflow = 'hidden'
        }
        const close = () => {
          box.classList.remove('open'); box.setAttribute('aria-hidden', 'true')
          document.body.style.overflow = ''; reset()
        }

        document.addEventListener('click', (e) => {
          const t = e.target
          if (t && t.tagName === 'IMG' && t.classList.contains('zoomable')) open(t)
        })
        closeBtn && closeBtn.addEventListener('click', (e) => { e.stopPropagation(); close() })
        prevBtn && prevBtn.addEventListener('click', (e) => { e.stopPropagation(); showAt(idx - 1) })
        nextBtn && nextBtn.addEventListener('click', (e) => { e.stopPropagation(); showAt(idx + 1) })
        const zoomBy = (f) => { scale = clamp(scale * f, 1, 5); if (scale === 1) { tx = 0; ty = 0 } apply() }
        zoomInBtn && zoomInBtn.addEventListener('click', (e) => { e.stopPropagation(); zoomBy(1.25) })
        zoomOutBtn && zoomOutBtn.addEventListener('click', (e) => { e.stopPropagation(); zoomBy(1 / 1.25) })

        box.addEventListener('pointerdown', (e) => {
          pts.set(e.pointerId, { x: e.clientX, y: e.clientY })
          moved = false
          if (pts.size === 1) { swipeStartX = e.clientX }
          if (pts.size === 2) {
            const v = [...pts.values()]; startDist = Math.hypot(v[0].x - v[1].x, v[0].y - v[1].y); startScale = scale
          } else if (pts.size === 1) {
            panStart = { x: e.clientX, y: e.clientY, tx: tx, ty: ty }
          }
        })
        box.addEventListener('pointermove', (e) => {
          if (!pts.has(e.pointerId)) return
          pts.set(e.pointerId, { x: e.clientX, y: e.clientY })
          if (pts.size === 2 && startDist) {
            const v = [...pts.values()]; const d = Math.hypot(v[0].x - v[1].x, v[0].y - v[1].y)
            scale = clamp(startScale * (d / startDist), 1, 5); apply(); moved = true
          } else if (pts.size === 1 && scale > 1 && panStart) {
            tx = panStart.tx + (e.clientX - panStart.x); ty = panStart.ty + (e.clientY - panStart.y); apply(); moved = true
          }
        })
        const end = (e) => {
          pts.delete(e.pointerId)
          if (pts.size < 2) startDist = 0
          if (pts.size === 0) {
            const dx = e.clientX - swipeStartX
            if (scale <= 1 && gallery.length > 1 && Math.abs(dx) > 50) {
              showAt(idx + (dx > 0 ? -1 : 1)) // swipe right = prev, left = next
              return
            }
            if (scale <= 1) { tx = 0; ty = 0; apply() }
            if (!moved && e.target === box) close() // tap on dark area closes
          } else if (pts.size === 1) {
            const p = [...pts.values()][0]; panStart = { x: p.x, y: p.y, tx: tx, ty: ty }
          }
        }
        box.addEventListener('pointerup', end)
        box.addEventListener('pointercancel', end)
        document.addEventListener('keydown', (e) => {
          if (!box.classList.contains("open")) return
          if (e.key === 'ArrowLeft') showAt(idx - 1)
          else if (e.key === 'ArrowRight') showAt(idx + 1)
        })
        box.addEventListener('wheel', (e) => {
          if (!box.classList.contains("open")) return
          e.preventDefault()
          scale = clamp(scale * (e.deltaY < 0 ? 1.06 : 1 / 1.06), 1, 5)
          if (scale === 1) { tx = 0; ty = 0 }
          apply()
        }, { passive: false })
        lbImg.addEventListener('dblclick', (e) => {
          e.preventDefault()
          if (scale > 1) reset(); else { scale = 2.5; apply() }
        })
      }
      document.addEventListener('astro:page-load', initLightbox)
    </script>
  </body>
</html>
