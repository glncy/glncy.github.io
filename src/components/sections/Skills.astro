---
import skills from '../../data/skills.json'

const total = skills.categories.reduce((n, g) => n + g.list.length, 0)
---

<div class="mb-10">
  <div class="mb-4 flex items-end justify-between">
    <div class="font-heading text-5xl text-gray-200 md:text-6xl">Skills</div>
    <div class="t-label mb-1">{total}+ tools</div>
  </div>
  <div class="hairline mb-6 w-full"></div>

  <div class="flex flex-col gap-4">
    {skills.categories.map((group) => (
      <div class="panel rounded-xl p-4 md:p-5">
        <div class="mb-4 text-lg font-semibold text-gray-100">{group.category}</div>
        <div class="grid grid-cols-3 gap-3 sm:grid-cols-4 md:grid-cols-6 xl:grid-cols-8">
          {group.list.map((item) => (
            <div class="skill group">
              <div class="skill-tile">
                {item.img ? (
                  <img src={item.img} alt={item.name} class="h-7 w-7 object-contain" />
                ) : (
                  <i class={`${item.icon} text-3xl text-gray-100`}></i>
                )}
              </div>
              <div class="skill-name">{item.name}</div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</div>

<style>
  .skill {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.45rem;
  }
  .skill-tile {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3.25rem;
    height: 3.25rem;
    border-radius: 0.7rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    transition: transform 0.15s ease, background 0.15s ease, border-color 0.15s ease;
  }
  .skill:hover .skill-tile {
    transform: translateY(-3px);
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.25);
  }
  .skill-name {
    font-size: 0.8rem;
    text-align: center;
    color: #d8dade;
    line-height: 1.1;
  }
</style>
