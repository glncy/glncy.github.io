---
import { getEntry, render } from 'astro:content'
import { Icon } from 'astro-icon/components'

const profile = await getEntry('profile', 'profile')
const { Content } = await render(profile!)
const data = profile!.data
---

<div class="mb-12">
  <div class="profile panel rounded-2xl p-5 md:p-7">
    <div class="flex flex-col items-center gap-6 xl:flex-row xl:items-start">
      <div class="shrink-0 text-center">
        <img
          src={data.image}
          alt={data.name}
          class="avatar mx-auto h-40 w-40 rounded-full object-cover xl:h-48 xl:w-48"
        />
        <div class="mt-4 font-heading text-2xl text-gray-100">{data.name}</div>
        <div class="text-sm text-gray-300">{data.role}</div>
        {data.tagline && <div class="mt-1 text-xs text-gray-400">{data.tagline}</div>}
        {data.location && (
          <div class="mt-2 inline-flex items-center gap-1 text-xs text-gray-400">
            <Icon name="ph:map-pin" /> {data.location}
          </div>
        )}
      </div>

      <div class="hidden w-px self-stretch bg-white/10 xl:block"></div>

      <div class="info text-[0.95rem] text-gray-200 xl:text-base">
        <Content />
      </div>
    </div>
  </div>
</div>

<style>
  .avatar {
    border: 2px solid rgba(255, 255, 255, 0.15);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
  }
  .info { line-height: 1.7; }
  .info :global(p) { margin-bottom: 0.9rem; }
  .info :global(p:last-child) { margin-bottom: 0; }
  .info :global(strong) { font-weight: 600; color: #f3f4f6; }
  .info :global(a) { color: #93c5fd; text-decoration: underline; }
  .info :global(img) { border-radius: 0.5rem; margin: 1rem 0; max-width: 100%; }
</style>
