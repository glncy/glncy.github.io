---
import { getCollection, render } from 'astro:content'
import { Icon } from 'astro-icon/components'

const jobs = (await getCollection('jobs', ({ data }) => !data.hidden)).sort((a, b) => b.data.order - a.data.order)
const rendered = await Promise.all(
  jobs.map(async (job) => ({ data: job.data, Content: (await render(job)).Content }))
)
---

<div>
  <div class="font-heading w-fit text-5xl text-gray-200 md:text-6xl">Job History</div>
  <div class="hairline my-4 w-full"></div>

  <ol class="timeline">
    {rendered.map(({ data, Content }) => (
      <li class="tl-item">
        <span class="tl-node"><Icon name="ph:briefcase" /></span>
        <div class="tl-body panel">
          <div class="tl-role">{data.title}</div>
          <div class="tl-company">{data.company} · <span class="tl-loc">{data.location}</span></div>
          <div class="tl-date">{data.startDate} – {data.endDate}</div>
          <div class="tl-desc"><Content /></div>
        </div>
      </li>
    ))}
  </ol>
</div>

<style>
  .timeline {
    position: relative;
    margin: 0;
    /* Leave room on the left for the node (centered on the line). */
    padding: 0 0 0 3rem;
    list-style: none;
  }
  .tl-item { position: relative; margin-bottom: 1.5rem; }
  .tl-item:last-child { margin-bottom: 0; }
  /* Connector: from THIS node's centre down to the NEXT node's centre.
     node centre x (item-relative) = -3rem + 1.1rem = -1.9rem;
     node centre y = node top (1.1rem) + half height (1.1rem) = 2.2rem.
     Height spans the rest of this item + the 1.5rem gap to the next node. */
  .tl-item::before {
    content: '';
    position: absolute;
    left: calc(-1.9rem - 1px);
    top: 2.2rem;
    width: 2px;
    height: calc(100% + 1.5rem);
    background: rgba(255, 255, 255, 0.16);
  }
  .tl-item:last-child::before { display: none; }
  .tl-node {
    position: absolute;
    /* Item content starts at padding-left (3rem). Place the 2.2rem node so its
       centre sits on the line (timeline x=1.1rem): left edge at timeline x=0,
       i.e. item-relative -3rem. */
    left: -3rem;
    top: 1.1rem;
    width: 2.2rem;
    height: 2.2rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    background: rgba(10, 12, 16, 0.95);
    border: 1px solid rgba(255, 255, 255, 0.28);
    color: #e5e7eb;
    box-shadow: 0 0 0 4px rgba(8, 10, 16, 0.6);
  }
  .tl-node :global(svg) { width: 1.15rem; height: 1.15rem; }
  .tl-body { border-radius: 0.7rem; padding: 1.1rem 1.25rem; }
  .tl-role { font-size: 1.3rem; font-weight: 500; color: #f3f4f6; }
  .tl-company { font-size: 0.95rem; color: #e5e7eb; opacity: 0.92; margin-top: 0.15rem; }
  .tl-loc { font-weight: 300; opacity: 0.85; }
  .tl-date { font-size: 0.8rem; font-style: italic; opacity: 0.7; margin-top: 0.2rem; }
  .tl-desc { font-size: 0.95rem; font-weight: 300; line-height: 1.6; color: #d8dade; margin-top: 0.6rem; }
  .tl-desc :global(p) { margin: 0; }
</style>
