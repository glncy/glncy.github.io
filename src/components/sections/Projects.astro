---
import { getCollection, render } from 'astro:content'
import { Icon } from 'astro-icon/components'
import Badge from '../Badge.astro'

const all = (await getCollection('projects', ({ data }) => !data.hidden)).sort((a, b) => b.data.order - a.data.order)
const rendered = await Promise.all(
  all.map(async (p) => ({ data: p.data, Content: (await render(p)).Content }))
)
const featured = rendered.filter((p) => p.data.featured)
const archive = rendered.filter((p) => !p.data.featured)

const techs = [...new Set(rendered.flatMap((p) => p.data.stack))].sort()

const ytId = (url: string) => {
  if (!url) return ''
  const m = url.match(/(?:youtu\.be\/|v=|embed\/)([\w-]{11})/)
  return m ? m[1] : url
}
---

<!-- Filter chips (multiple allowed) -->
<div class="filters" role="group" aria-label="Filter projects by tech (multiple allowed)">
  <button class="chip active" data-tech="all" aria-pressed="true">All</button>
  {techs.map((t) => <button class="chip" data-tech={t} aria-pressed="false">{t}</button>)}
</div>

{featured.length > 0 && (
  <section class="mb-10" id="featured-section">
    <div class="font-heading mb-4 w-fit text-4xl text-gray-200">Featured</div>
    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
      {featured.map(({ data, Content }) => (
        <article class="proj panel panel-hover flex flex-col rounded-lg" data-stack={data.stack.join('|')}>
          {data.youtube ? (
            <iframe class="aspect-video w-full rounded-t-lg" src={`https://www.youtube-nocookie.com/embed/${ytId(data.youtube)}`} title={data.name} loading="lazy" allowfullscreen></iframe>
          ) : data.thumbnail ? (
            <img src={data.thumbnail} alt={data.name} class="w-full rounded-t-lg object-cover" />
          ) : null}
          <div class="p-4">
            <div class="text-xl text-gray-200">{data.name}</div>
            <div class="text-sm font-extralight italic text-gray-200">{data.year}</div>
            <div class="mb-2 mt-2 flex flex-wrap gap-1.5">
              {data.stack.map((s) => <Badge>{s}</Badge>)}
            </div>
            <ul class="ml-4 list-disc text-sm font-light text-gray-200">
              {data.contributions.map((c) => <li>{c}</li>)}
            </ul>
            <div class="hairline my-2"></div>
            <div class="remarks text-sm text-gray-200"><Content /></div>
          </div>
        </article>
      ))}
    </div>
  </section>
)}

<section id="archive-section">
  <div class="font-heading mb-4 w-fit text-4xl text-gray-200">All Projects</div>
  <div class="masonry cols-3" id="archive-grid">
    {archive.map(({ data, Content }) => (
      <article class="proj panel panel-hover flex flex-col rounded-lg" data-stack={data.stack.join('|')}>
        <div class="p-4">
          <div class="text-xl text-gray-200">{data.name}</div>
          <div class="text-sm font-extralight italic text-gray-200">{data.year}</div>
          <div class="mb-2 mt-2 flex flex-wrap gap-1.5">
            {data.stack.map((s) => <Badge>{s}</Badge>)}
          </div>
          <ul class="ml-4 list-disc text-sm font-light text-gray-200">
            {data.contributions.map((c) => <li>{c}</li>)}
          </ul>
          <div class="hairline my-2"></div>
          <div class="remarks text-sm text-gray-200"><Content /></div>
        </div>
      </article>
    ))}
  </div>
  <p class="no-results empty-state hidden">No projects match the selected tech.</p>
</section>

<style>
  .filters { display: flex; flex-wrap: wrap; gap: 0.5rem; justify-content: center; margin-bottom: 1.5rem; }
  .chip {
    padding: 0.3rem 0.8rem;
    border-radius: 9999px;
    font-size: 0.8rem;
    color: #e5e7eb;
    background: rgba(6, 8, 12, 0.78);
    border: 1px solid rgba(255, 255, 255, 0.16);
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }
  .chip:hover { background: rgba(34, 38, 47, 0.92); border-color: rgba(255, 255, 255, 0.32); }
  .chip.active { background: #e5e7eb; color: #0a0c10; border-color: #e5e7eb; font-weight: 600; }
  .remarks :global(a) { color: #3b82f6; text-decoration: underline; }
  .remarks :global(p) { margin: 0; }
</style>

<script is:inline>
  function initProjectFilter() {
    const chips = document.querySelectorAll('.chip')
    if (!chips.length) return
    const cards = document.querySelectorAll('.proj')
    const noResults = document.querySelector('.no-results')
    const active = new Set() // empty = all (multi-select, OR match)

    function syncChips() {
      chips.forEach((c) => {
        const on = c.dataset.tech === 'all' ? active.size === 0 : active.has(c.dataset.tech)
        c.classList.toggle('active', on)
        c.setAttribute('aria-pressed', on ? 'true' : 'false')
      })
    }
    const featuredSection = document.getElementById('featured-section')
    const archiveSection = document.getElementById('archive-section')
    const visibleIn = (section) =>
      section
        ? Array.from(section.querySelectorAll('.proj')).some((c) => c.style.display !== 'none')
        : false
    function apply() {
      let shown = 0
      cards.forEach((card) => {
        const stacks = (card.dataset.stack || '').split('|').filter(Boolean)
        const match = active.size === 0 || stacks.some((s) => active.has(s))
        card.style.display = match ? '' : 'none'
        if (match) shown++
      })
      // Hide a section's heading when none of its cards are visible.
      if (featuredSection) featuredSection.style.display = visibleIn(featuredSection) ? '' : 'none'
      if (archiveSection) archiveSection.style.display = visibleIn(archiveSection) ? '' : 'none'
      if (noResults) noResults.classList.toggle('hidden', shown > 0)
    }
    chips.forEach((chip) => {
      if (chip.dataset.bound) return
      chip.dataset.bound = '1'
      chip.addEventListener('click', () => {
        const tech = chip.dataset.tech
        if (tech === 'all') active.clear()
        else if (active.has(tech)) active.delete(tech)
        else active.add(tech)
        syncChips()
        apply()
      })
    })
  }
  document.addEventListener('astro:page-load', initProjectFilter)
</script>
