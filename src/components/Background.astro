---
import settings from '../data/settings.json'

const videos = settings.backgroundVideos
---

<!-- Fixed animated background -->
<div class="bg-fixed-layer">
  <div id="yt-bg"></div>
  <div class="bg-fallback" id="bg-fallback"></div>
  <div class="bg-overlay"></div>
  <div style="position:absolute;inset:0;overflow:hidden;">
    <div class="bg-noise"></div>
  </div>
</div>

<!-- Glass music player (fixed bottom) -->
<div class="player glass" id="player" hidden>
  <div class="player-info" id="player-info" title="Open on YouTube">
    <div class="player-title" id="player-title">Love music? Click unmute. :)</div>
    <div class="player-channel" id="player-channel"></div>
  </div>
  <div class="player-controls">
    <button class="pbtn" id="prev" aria-label="Previous">‹‹</button>
    <button class="pbtn" id="toggle" aria-label="Play/Pause">►</button>
    <button class="pbtn" id="mute" aria-label="Mute/Unmute">🔇</button>
    <button class="pbtn" id="next" aria-label="Next">››</button>
  </div>
</div>

<style>
  #yt-bg {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: max(100vw, 177.78vh);
    height: max(100vh, 56.25vw);
    pointer-events: none;
  }
  #yt-bg :global(iframe) { width: 100%; height: 100%; }

  .player {
    position: fixed;
    bottom: 1rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 30;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0.75rem 1rem;
    border-radius: 0.75rem;
    text-align: center;
    transition: opacity 0.3s ease-in-out;
  }
  .player.idle { opacity: 0.25; }
  .player-info { cursor: pointer; max-width: 30ch; }
  .player-title { font-size: 0.75rem; font-weight: 500; }
  .player-channel { font-size: 0.7rem; font-weight: 300; opacity: 0.85; margin-top: 0.15rem; }
  .player-controls { display: flex; align-items: center; gap: 1rem; margin-top: 0.5rem; }
  .pbtn {
    background: none;
    border: none;
    color: #e5e7eb;
    font-size: 1.1rem;
    line-height: 1;
    cursor: pointer;
    transition: transform 0.1s ease;
  }
  .pbtn:hover { transform: scale(1.25); }
</style>

<script is:inline define:vars={{ videos }}>
  // Pick a random starting track each load.
  let index = Math.floor(Math.random() * videos.length)
  let player = null
  let isPlaying = false
  let isMuted = true
  let lastInteract = Date.now()

  const $ = (id) => document.getElementById(id)
  const fallback = $('bg-fallback')
  const playerEl = $('player')
  const titleEl = $('player-title')
  const channelEl = $('player-channel')
  const toggleBtn = $('toggle')
  const muteBtn = $('mute')

  function loadYouTubeAPI() {
    return new Promise((resolve) => {
      if (window.YT && window.YT.Player) return resolve()
      const tag = document.createElement('script')
      tag.src = 'https://www.youtube.com/iframe_api'
      window.onYouTubeIframeAPIReady = () => resolve()
      document.head.appendChild(tag)
    })
  }

  function current() { return videos[index] }

  function updateInfo() {
    const v = current()
    if (isPlaying) {
      titleEl.textContent = v.title
      channelEl.textContent = v.channel
    }
  }

  function setFallback(hidden) { fallback.style.opacity = hidden ? '0' : '1' }

  async function init() {
    await loadYouTubeAPI()
    player = new YT.Player('yt-bg', {
      videoId: current().id,
      playerVars: {
        autoplay: 1, mute: 1, controls: 0, loop: 1,
        playlist: current().id, rel: 0, showinfo: 0, playsinline: 1,
        modestbranding: 1,
      },
      events: {
        onReady: () => { player.playVideo(); playerEl.hidden = false },
        onStateChange: (e) => {
          if (e.data === YT.PlayerState.PLAYING) {
            isPlaying = true
            toggleBtn.textContent = '❚❚'
            setFallback(true)
            updateInfo()
          } else if (e.data === YT.PlayerState.ENDED) {
            changeVideo(1)
          } else {
            isPlaying = false
            toggleBtn.textContent = '►'
            setFallback(false)
          }
        },
        onError: () => changeVideo(1),
      },
    })
  }

  function changeVideo(dir) {
    index = (index + dir + videos.length) % videos.length
    const v = current()
    player.loadVideoById(v.id)
    player.setLoop(true)
    interact()
  }

  function interact() { lastInteract = Date.now(); playerEl.classList.remove('idle') }

  // Wire controls
  $('prev').addEventListener('click', () => changeVideo(-1))
  $('next').addEventListener('click', () => changeVideo(1))
  toggleBtn.addEventListener('click', () => {
    if (!player) return
    isPlaying ? player.pauseVideo() : player.playVideo()
    interact()
  })
  muteBtn.addEventListener('click', () => {
    if (!player) return
    if (isMuted) { player.unMute(); player.setVolume(80); isMuted = false; muteBtn.textContent = '🔊' }
    else { player.mute(); isMuted = true; muteBtn.textContent = '🔇' }
    interact()
  })
  $('player-info').addEventListener('click', () => {
    window.open(`https://www.youtube.com/watch?v=${current().id}`, '_blank')
  })

  // Auto-dim the player when idle.
  setInterval(() => {
    if (Date.now() - lastInteract > 5000) playerEl.classList.add('idle')
  }, 1000)

  init()
</script>
