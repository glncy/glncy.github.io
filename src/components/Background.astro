---
import background from '../data/background.json'

const videos = background.videos

// Pre-generate the animated glitch scanlines (ported from the original site).
const lines = Array.from({ length: 40 }, (_, i) => {
  const pct = 16 + Math.floor(Math.random() * 8) // 16–24
  const height = 2 + Math.floor(Math.random() * 8) // 2–10px
  return {
    height,
    top: `calc(200% - ${i * pct}%)`,
    endTop: `calc(100% - ${i * pct}%)`,
  }
})
---

<!-- Persisted across navigation so the video + player never restart. -->
<div transition:persist="background-player">
<!-- Fixed animated background -->
<div class="bg-fixed-layer">
  <div class="yt-wrapper" id="yt-wrapper">
    <div id="yt-bg"></div>
  </div>
  <div class="bg-fallback" id="bg-fallback"></div>
  <div class="glitch-lines">
    {lines.map((l) => (
      <div
        class="glitch-line"
        style={`--top:${l.top};--endTop:${l.endTop};height:${l.height}px;`}
      ></div>
    ))}
  </div>
  <div class="bg-overlay"></div>
  <div style="position:absolute;inset:0;overflow:hidden;">
    <div class="bg-noise"></div>
  </div>
</div>

<!-- Glass music player (fixed bottom). Phosphor (fill) icons. -->
<div class="player glass" id="player" hidden>
  <div class="player-info" id="player-info" title="Open on YouTube">
    <div class="player-title" id="player-title">Love music? Click unmute. :)</div>
    <div class="player-channel" id="player-channel"></div>
  </div>
  <div class="player-controls">
    <button class="pbtn" id="prev" aria-label="Previous">
      <svg viewBox="0 0 256 256" fill="currentColor"><path d="M208,47.88V208.12a16,16,0,0,1-24.43,13.43L64,146.77V216a8,8,0,0,1-16,0V40a8,8,0,0,1,16,0v69.23L183.57,34.45A15.95,15.95,0,0,1,208,47.88Z"/></svg>
    </button>
    <button class="pbtn" id="toggle" aria-label="Play/Pause">
      <svg id="icon-play" viewBox="0 0 256 256" fill="currentColor"><path d="M240,128a15.74,15.74,0,0,1-7.6,13.51L88.32,229.65a16,16,0,0,1-16.2.3A15.86,15.86,0,0,1,64,216.13V39.87a15.86,15.86,0,0,1,8.12-13.82,16,16,0,0,1,16.2.3L232.4,114.49A15.74,15.74,0,0,1,240,128Z"/></svg>
      <svg id="icon-pause" viewBox="0 0 256 256" fill="currentColor" hidden><path d="M216,48V208a16,16,0,0,1-16,16H160a16,16,0,0,1-16-16V48a16,16,0,0,1,16-16h40A16,16,0,0,1,216,48ZM96,32H56A16,16,0,0,0,40,48V208a16,16,0,0,0,16,16H96a16,16,0,0,0,16-16V48A16,16,0,0,0,96,32Z"/></svg>
    </button>
    <button class="pbtn" id="mute" aria-label="Mute/Unmute">
      <svg id="icon-muted" viewBox="0 0 256 256" fill="currentColor"><path d="M213.92,210.62a8,8,0,1,1-11.84,10.76L160,175.09v48.6a8.29,8.29,0,0,1-3.91,7.18,8,8,0,0,1-9-.56l-65.55-51A4,4,0,0,1,80,176.18V87.09L42.08,45.38A8,8,0,1,1,53.92,34.62Zm-27.21-55.46a8,8,0,0,0,11.29-.7,40,40,0,0,0,0-52.88,8,8,0,1,0-12,10.57,24,24,0,0,1,0,31.72A8,8,0,0,0,186.71,155.16Zm40.92-80.49a8,8,0,1,0-11.92,10.66,64,64,0,0,1,0,85.34,8,8,0,1,0,11.92,10.66,80,80,0,0,0,0-106.66ZM153,119.87a4,4,0,0,0,7-2.7V32.25a8.27,8.27,0,0,0-2.88-6.4,8,8,0,0,0-10-.16L103.83,59.33a4,4,0,0,0-.5,5.85Z"/></svg>
      <svg id="icon-unmuted" viewBox="0 0 256 256" fill="currentColor" hidden><path d="M160,32.25V223.69a8.29,8.29,0,0,1-3.91,7.18,8,8,0,0,1-9-.56l-65.57-51A4,4,0,0,1,80,176.16V79.84a4,4,0,0,1,1.55-3.15l65.57-51a8,8,0,0,1,10,.16A8.27,8.27,0,0,1,160,32.25ZM60,80H32A16,16,0,0,0,16,96v64a16,16,0,0,0,16,16H60a4,4,0,0,0,4-4V84A4,4,0,0,0,60,80Zm126.77,20.84a8,8,0,0,0-.72,11.3,24,24,0,0,1,0,31.72,8,8,0,1,0,12,10.58,40,40,0,0,0,0-52.88A8,8,0,0,0,186.74,100.84Zm40.89-26.17a8,8,0,1,0-11.92,10.66,64,64,0,0,1,0,85.34,8,8,0,1,0,11.92,10.66,80,80,0,0,0,0-106.66Z"/></svg>
    </button>
    <button class="pbtn" id="next" aria-label="Next">
      <svg viewBox="0 0 256 256" fill="currentColor"><path d="M208,40V216a8,8,0,0,1-16,0V146.77L72.43,221.55A15.95,15.95,0,0,1,48,208.12V47.88A15.95,15.95,0,0,1,72.43,34.45L192,109.23V40a8,8,0,0,1,16,0Z"/></svg>
    </button>
  </div>
</div>
</div>

<style>
  /* YT.Player replaces #yt-bg with an <iframe> that keeps this id.
     Cover the viewport AND overscan (scale) so YouTube's title bar and
     controls sit off-screen; pointer-events:none stops hover UI. */
  /* Wrapper is sized by JS to a 16:9 box larger than the viewport (overscan),
     so YouTube's title bar (top) and "More videos"/logo (bottom) sit off-screen
     while the video covers fully with no black bars. Ported from the Vue site. */
  .yt-wrapper {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
  }
  #yt-bg {
    display: block;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .player {
    position: fixed;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 30;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0.85rem 1.25rem;
    border-radius: 0.85rem;
    text-align: center;
    transition: transform 0.1s ease-in-out;
  }
  /* While playing, tuck the player down on large screens; hover slides it back
     up (ported from the original Vue site — no opacity fade). */
  @media (min-width: 1024px) {
    .player.playing { transform: translateX(-50%) translateY(3rem); }
    .player.playing:hover { transform: translateX(-50%) translateY(0); }
  }
  /* When idle, hide the now-playing title — on mobile only (desktop keeps it). */
  .player.idle-title .player-info { display: none; }
  @media (min-width: 768px) {
    .player.idle-title .player-info { display: block; }
  }
  .player-info { cursor: pointer; max-width: 30ch; margin-bottom: 0.7rem; }
  .player-title { font-size: 0.75rem; font-weight: 500; }
  .player-channel { font-size: 0.7rem; font-weight: 300; opacity: 0.85; margin-top: 0.15rem; }
  .player-controls { display: flex; align-items: center; gap: 0.85rem; }
  .pbtn {
    background: none;
    border: none;
    color: #e5e7eb;
    line-height: 0;
    cursor: pointer;
    padding: 0;
    transition: transform 0.1s ease;
  }
  .pbtn svg { width: 1.25rem; height: 1.25rem; }
  .pbtn svg:not([hidden]) { display: block; }
  .pbtn svg[hidden] { display: none; }
  .pbtn:hover { transform: scale(1.2); }
</style>

<script is:inline define:vars={{ videos }}>
  // Runs once for the lifetime of the persisted background (ClientRouter keeps
  // the DOM + this state alive across page navigations).
  if (!window.__bgInit) {
  window.__bgInit = true

  // Pick a random starting track each load.
  let index = Math.floor(Math.random() * videos.length)
  let player = null
  let isPlaying = false
  let isMuted = true
  let isFirstLoad = true // show "Click unmute" prompt until the user unmutes once
  let lastInteract = Date.now()

  const $ = (id) => document.getElementById(id)
  const wrapper = $('yt-wrapper')
  const fallback = $('bg-fallback')

  // Size the player to a 16:9 box bigger than the viewport so it covers fully
  // AND YouTube's chrome (title/logo/more-videos) overscans off-screen.
  function sizeWrapper() {
    const w = Math.max(window.innerWidth * 1.18, window.innerHeight * 2.1)
    wrapper.style.width = w + 'px'
    wrapper.style.height = (w * 9) / 16 + 'px'
  }
  sizeWrapper()
  window.addEventListener('resize', sizeWrapper)
  const playerEl = $('player')
  const titleEl = $('player-title')
  const channelEl = $('player-channel')
  const toggleBtn = $('toggle')
  const muteBtn = $('mute')
  const iconPlay = $('icon-play')
  const iconPause = $('icon-pause')
  const iconMuted = $('icon-muted')
  const iconUnmuted = $('icon-unmuted')

  // Use toggleAttribute (not .hidden) — SVG elements don't reflect the .hidden
  // DOM property to the attribute, so CSS [hidden] wouldn't update.
  function setPlayIcon() {
    iconPlay.toggleAttribute('hidden', isPlaying)
    iconPause.toggleAttribute('hidden', !isPlaying)
  }
  function setMuteIcon() {
    iconMuted.toggleAttribute('hidden', !isMuted)
    iconUnmuted.toggleAttribute('hidden', isMuted)
  }

  function loadYouTubeAPI() {
    return new Promise((resolve) => {
      if (window.YT && window.YT.Player) return resolve()
      const tag = document.createElement('script')
      tag.src = 'https://www.youtube.com/iframe_api'
      window.onYouTubeIframeAPIReady = () => resolve()
      document.head.appendChild(tag)
    })
  }

  function current() { return videos[index] }

  function updateInfo() {
    // Keep the "Click unmute" prompt until the user has unmuted at least once.
    if (isFirstLoad) return
    const v = current()
    titleEl.textContent = v.title
    channelEl.textContent = v.channel
  }

  function setFallback(hidden) { fallback.style.opacity = hidden ? '0' : '1' }

  async function init() {
    await loadYouTubeAPI()
    player = new YT.Player('yt-bg', {
      width: '100%',
      height: '100%',
      videoId: current().id,
      playerVars: {
        autoplay: 1, mute: 1, controls: 0, loop: 1,
        playlist: current().id, rel: 0, showinfo: 0, playsinline: 1,
        modestbranding: 1, iv_load_policy: 3, fs: 0, disablekb: 1,
        cc_load_policy: 0,
      },
      events: {
        onReady: () => { player.playVideo(); playerEl.hidden = false },
        onStateChange: (e) => {
          if (e.data === YT.PlayerState.PLAYING) {
            isPlaying = true
            setPlayIcon()
            setFallback(true)
            updateInfo()
            updateClasses()
          } else if (e.data === YT.PlayerState.ENDED) {
            changeVideo(1)
          } else {
            // Paused/buffering: keep the paused video frame visible.
            isPlaying = false
            setPlayIcon()
            updateClasses()
          }
        },
        onError: () => changeVideo(1),
      },
    })
  }

  function changeVideo(dir) {
    index = (index + dir + videos.length) % videos.length
    const v = current()
    player.loadVideoById(v.id)
    player.setLoop(true)
    // Preserve mute state across track changes.
    if (isMuted) player.mute()
    else { player.unMute(); player.setVolume(80) }
    updateInfo()
    interact()
  }

  // `playing` -> tuck down on desktop while a track plays (hover reveals).
  // `idle-title` -> hide the now-playing title on mobile after 5s idle.
  function updateClasses() {
    const idle = Date.now() - lastInteract > 5000
    playerEl.classList.toggle('playing', isPlaying && !isFirstLoad)
    playerEl.classList.toggle('idle-title', idle && !isFirstLoad)
  }

  function interact() { lastInteract = Date.now(); updateClasses() }

  // Wire controls
  $('prev').addEventListener('click', () => changeVideo(-1))
  $('next').addEventListener('click', () => changeVideo(1))
  // Real play/pause.
  toggleBtn.addEventListener('click', () => {
    if (!player) return
    isPlaying ? player.pauseVideo() : player.playVideo()
    interact()
  })
  // Separate mute/unmute. First unmute restarts the track with audio (Vue parity).
  muteBtn.addEventListener('click', () => {
    if (!player) return
    if (isMuted) {
      if (isFirstLoad) { isFirstLoad = false; player.seekTo(0); player.playVideo() }
      player.unMute()
      player.setVolume(80)
      isMuted = false
      updateInfo()
    } else {
      player.mute()
      isMuted = true
    }
    setMuteIcon()
    interact()
  })
  $('player-info').addEventListener('click', () => {
    window.open(`https://www.youtube.com/watch?v=${current().id}`, '_blank')
  })
  // Un-dim while hovering the player.
  playerEl.addEventListener('mouseenter', interact)

  // Re-evaluate idle/playing state every second.
  setInterval(updateClasses, 1000)

  init()
  }
</script>
