---
interface Props {
  title: string
  subtitle?: string
  plain?: boolean // when true, no glass box — title floats on the background
}
const { title, subtitle, plain = false } = Astro.props
---

<div class:list={['title-box', plain ? 'plain' : 'glass']}>
  <div class="font-heading title">{title}</div>
  {subtitle && <div class="subtitle" set:html={subtitle} />}
</div>

<style>
  .title-box {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    width: 100%;
    transition: all 0.3s ease-in-out;
  }
  /* Polished frosted hero box. Mobile: full-width band, NO radius (top/bottom
     borders only). Desktop: rounded card with soft shadow + top highlight. */
  .title-box.glass {
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.42),
      rgba(0, 0, 0, 0.24)
    );
    /* Explicit, slightly stronger frost for the hero (a single element, so the
       backdrop-filter cost here is fine). */
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border: none;
    border-top: 1px solid rgba(255, 255, 255, 0.18);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 0;
  }
  @media (min-width: 768px) {
    .title-box.glass {
      width: auto;
      padding: 2.25rem 3rem;
      border: 1px solid rgba(255, 255, 255, 0.14);
      border-top-color: rgba(255, 255, 255, 0.28);
      border-radius: 1rem;
      box-shadow: 0 12px 48px rgba(0, 0, 0, 0.35);
    }
  }
  /* Boxless variant: drop the panel, lean on text-shadow for legibility. */
  .title-box.plain {
    padding: 1rem;
    width: auto;
  }
  .title-box.plain .title,
  .title-box.plain .subtitle {
    text-shadow: 0 2px 24px rgba(0, 0, 0, 0.7), 0 1px 4px rgba(0, 0, 0, 0.6);
  }
  .title {
    font-size: clamp(2.75rem, 9vw, 6rem);
    font-weight: 500;
    line-height: 1.05;
    letter-spacing: -0.015em;
    text-align: center;
    color: #e5e7eb;
  }
  .subtitle {
    margin-top: 0.75rem;
    font-size: clamp(0.875rem, 1.6vw, 1.25rem);
    font-weight: 300;
    text-align: center;
    color: #e5e7eb;
  }
  .subtitle :global(a) { color: #3b82f6; text-decoration: underline; }
</style>
