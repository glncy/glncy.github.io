---
interface Props {
  title: string
  subtitle?: string
  plain?: boolean // when true, no glass box — title floats on the background
}
const { title, subtitle, plain = false } = Astro.props
---

<div class:list={['title-box', plain ? 'plain' : 'glass']}>
  <div class="font-heading title">{title}</div>
  {subtitle && <div class="subtitle" set:html={subtitle} />}
</div>

<style>
  .title-box {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    width: 100%;
    transition: all 0.3s ease-in-out;
  }
  @media (min-width: 768px) {
    .title-box.glass { width: auto; border-radius: 0.375rem; }
    .title-box.glass:hover { background: rgba(0, 0, 0, 0); border-color: rgba(255, 255, 255, 0); }
  }
  /* Boxless variant: drop the panel, lean on text-shadow for legibility. */
  .title-box.plain {
    padding: 1rem;
    width: auto;
  }
  .title-box.plain .title,
  .title-box.plain .subtitle {
    text-shadow: 0 2px 24px rgba(0, 0, 0, 0.7), 0 1px 4px rgba(0, 0, 0, 0.6);
  }
  .title {
    font-size: 3rem;
    font-weight: 500;
    text-align: center;
    color: #e5e7eb;
  }
  @media (min-width: 768px) { .title { font-size: 6rem; } }
  .subtitle {
    margin-top: 0.5rem;
    font-size: 0.875rem;
    font-weight: 300;
    text-align: center;
    color: #e5e7eb;
  }
  @media (min-width: 768px) { .subtitle { margin-top: 1rem; font-size: 1.25rem; } }
  .subtitle :global(a) { color: #3b82f6; text-decoration: underline; }
</style>
