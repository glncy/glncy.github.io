---
import { Icon } from 'astro-icon/components'
import settings from '../data/settings.json'

const path = Astro.url.pathname
const isHome = path === '/'
const isActive = (href: string) => path.startsWith(href)
const writingActive =
  path.startsWith('/writing') || path.startsWith('/blog') || path.startsWith('/til')
---

<header id="site-header" class:list={['site-header', { home: isHome }]}>
  <a href="/" class="font-heading brand">{settings.siteTitle}</a>

  {!isHome && (
    <nav class="nav" aria-label="Primary">
      <a href="/about" class:list={['nav-link', { active: isActive('/about') }]}>About</a>
      <a href="/projects" class:list={['nav-link', { active: isActive('/projects') }]}>Projects</a>

      <div class="nav-dd">
        <a
          href="/writing"
          aria-haspopup="true"
          class:list={['nav-link', 'dd-toggle', { active: writingActive }]}
        >
          Writing <Icon name="ph:caret-down" />
        </a>
        <div class="dd-menu">
          <a href="/blog" class="dd-item">Blog</a>
          <a href="/til" class="dd-item">TIL</a>
        </div>
      </div>

      <a href="/contact" class:list={['nav-link', { active: isActive('/contact') }]}>Contact</a>
    </nav>
  )}
</header>

<style>
  .site-header {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 40;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    padding: 1.1rem 1.25rem 1.6rem;
  }
  /* Soft top-down scrim — fades in only once scrolled. No size/collapse change. */
  .site-header::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background: linear-gradient(to bottom, rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0));
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  .site-header.scrolled::before {
    opacity: 1;
  }
  .brand {
    font-style: italic;
    font-weight: 500;
    font-size: 1.7rem;
    color: #f3f4f6;
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.5);
  }
  .nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 1.5rem;
  }
  .nav-link {
    color: #e5e7eb;
    font-size: 1rem;
    opacity: 0.85;
    transition: opacity 0.15s ease, transform 0.15s ease;
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.5);
  }
  .nav-link:hover { opacity: 1; transform: scale(1.08); }
  .nav-link.active { opacity: 1; text-decoration: underline; text-underline-offset: 6px; }

  /* Writing dropdown */
  .nav-dd { position: relative; }
  .dd-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
  }
  .dd-toggle :global(svg) {
    width: 0.8rem;
    height: 0.8rem;
    transition: transform 0.15s ease;
  }
  .nav-dd:hover .dd-toggle :global(svg) { transform: rotate(180deg); }
  .dd-menu {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(4px);
    display: flex;
    flex-direction: column;
    min-width: 8.5rem;
    padding: 0.4rem;
    border-radius: 0.6rem;
    background: rgba(10, 12, 16, 0.7);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.14);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.4);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.15s ease, transform 0.15s ease;
  }
  .nav-dd:hover .dd-menu,
  .nav-dd:focus-within .dd-menu {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(8px);
  }
  /* hover bridge so the menu doesn't close in the gap below the toggle */
  .nav-dd::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    height: 12px;
  }
  .dd-item {
    color: #e5e7eb;
    padding: 0.45rem 0.7rem;
    border-radius: 0.4rem;
    font-size: 0.95rem;
    opacity: 0.85;
    text-align: center;
    transition: background 0.15s ease, opacity 0.15s ease;
  }
  .dd-item:hover { opacity: 1; background: rgba(255, 255, 255, 0.1); }
</style>

<script is:inline>
  // Fade the scrim in once scrolled (no size/collapse change). Idempotent across
  // ClientRouter navigations (remove any prior window scroll handler first).
  function initHeaderScrim() {
    const header = document.getElementById('site-header')
    if (!header) return
    const onScroll = () => header.classList.toggle('scrolled', window.scrollY > 8)
    if (window.__headerScroll) window.removeEventListener('scroll', window.__headerScroll)
    window.__headerScroll = onScroll
    window.addEventListener('scroll', onScroll, { passive: true })
    onScroll()
  }
  document.addEventListener('astro:page-load', initHeaderScrim)
</script>
