---
import settings from '../data/settings.json'
import WritingNav from './WritingNav.astro'

const path = Astro.url.pathname
const isHome = path === '/'
const isActive = (href: string) => path.startsWith(href)
const writingActive =
  path.startsWith('/posts') || path.startsWith('/blog') || path.startsWith('/til')
---

<header id="site-header" class:list={['site-header', { home: isHome }]}>
  <a href="/" class="font-heading brand">{settings.siteTitle}</a>

  {!isHome && (
    <nav class="nav" aria-label="Primary">
      <a href="/about" class:list={['nav-link', { active: isActive('/about') }]}>About</a>
      <a href="/services" class:list={['nav-link', { active: isActive('/services') }]}>Services</a>
      <a href="/projects" class:list={['nav-link', { active: isActive('/projects') }]}>Projects</a>
      <WritingNav active={writingActive} />
      <a href="/contact" class:list={['nav-link', { active: isActive('/contact') }]}>Contact</a>
    </nav>
  )}
</header>

<style>
  .site-header {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 40;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    padding: 1.1rem 1.25rem 1.6rem;
  }
  /* Soft top-down scrim — fades in only once scrolled. No size/collapse change. */
  .site-header::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background: linear-gradient(to bottom, rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0));
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  .site-header.scrolled::before {
    opacity: 1;
  }
  .brand {
    font-style: italic;
    font-weight: 500;
    font-size: 1.7rem;
    color: #f3f4f6;
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.5);
  }
  .nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 1.5rem;
  }
  .nav-link {
    color: #e5e7eb;
    font-size: 1rem;
    opacity: 0.85;
    transition: opacity 0.15s ease, transform 0.15s ease;
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.5);
  }
  .nav-link:hover { opacity: 1; transform: scale(1.08); }
  .nav-link.active { opacity: 1; text-decoration: underline; text-underline-offset: 6px; }
</style>

<script is:inline>
  // Fade the scrim in once scrolled (no size/collapse change). Idempotent across
  // ClientRouter navigations (remove any prior window scroll handler first).
  function initHeaderScrim() {
    const header = document.getElementById('site-header')
    if (!header) return
    const onScroll = () => header.classList.toggle('scrolled', window.scrollY > 8)
    if (window.__headerScroll) window.removeEventListener('scroll', window.__headerScroll)
    window.__headerScroll = onScroll
    window.addEventListener('scroll', onScroll, { passive: true })
    onScroll()
  }
  document.addEventListener('astro:page-load', initHeaderScrim)
</script>
