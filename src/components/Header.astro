---
import settings from '../data/settings.json'

const path = Astro.url.pathname
const isHome = path === '/'
const links = [
  { href: '/about', label: 'About' },
  { href: '/projects', label: 'Projects' },
  { href: '/writing', label: 'Writing' },
  { href: '/contact', label: 'Contact' },
]
const isActive = (href: string) => {
  if (href === '/writing') {
    return path.startsWith('/writing') || path.startsWith('/blog') || path.startsWith('/til')
  }
  return path.startsWith(href)
}
---

<header id="site-header" class:list={['site-header', { home: isHome }]}>
  <a href="/" class="font-heading brand">{settings.siteTitle}</a>

  {!isHome && (
    <nav class="nav" aria-label="Primary">
      {links.map((l) => (
        <a href={l.href} class:list={['nav-link', { active: isActive(l.href) }]}>{l.label}</a>
      ))}
    </nav>
  )}
</header>

<style>
  .site-header {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 40;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    padding: 1.1rem 1.25rem 1.6rem;
    /* Soft top-down scrim for legibility — no hard band/box edge. */
    background: linear-gradient(to bottom, rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0));
  }
  .brand {
    font-style: italic;
    font-weight: 500;
    font-size: 1.7rem;
    color: #f3f4f6;
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.5);
  }
  .nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 1.5rem;
  }
  .nav-link {
    color: #e5e7eb;
    font-size: 1rem;
    opacity: 0.85;
    transition: opacity 0.15s ease, transform 0.15s ease;
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.5);
  }
  .nav-link:hover { opacity: 1; transform: scale(1.08); }
  .nav-link.active { opacity: 1; text-decoration: underline; text-underline-offset: 6px; }
</style>
