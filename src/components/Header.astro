---
import settings from '../data/settings.json'
import WritingNav from './WritingNav.astro'
import { Icon } from 'astro-icon/components'

const path = Astro.url.pathname
const isHome = path === '/'
const isActive = (href: string) => path.startsWith(href)
const writingActive =
  path.startsWith('/posts') || path.startsWith('/blog') || path.startsWith('/til')
---

<header id="site-header" class:list={['site-header', { home: isHome }]}>
  <a href="/" class="font-heading brand">{settings.siteTitle}</a>

  {!isHome && (
    <nav class="nav" id="primary-nav" aria-label="Primary">
      <a href="/about" class:list={['nav-link', { active: isActive('/about') }]}>About</a>
      <a href="/services" class:list={['nav-link', { active: isActive('/services') }]}>Services</a>
      <a href="/projects" class:list={['nav-link', { active: isActive('/projects') }]}>Projects</a>
      <WritingNav active={writingActive} />
      <a href="/contact" class:list={['nav-link', { active: isActive('/contact') }]}>Contact</a>

      <!-- Overflow links are moved in here by JS when they don't fit on one line. -->
      <div class="more-wrap" id="nav-more" hidden>
        <button class="nav-link more-btn" id="nav-more-btn" aria-haspopup="true" aria-expanded="false">
          More <Icon name="ph:caret-down" class="more-caret" />
        </button>
        <div class="more-menu" id="nav-more-menu" role="menu"></div>
      </div>
    </nav>
  )}
</header>

<style>
  .site-header {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 40;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    padding: 1.1rem 1.25rem 1.6rem;
  }
  /* Soft top-down scrim — fades in only once scrolled. No size/collapse change. */
  .site-header::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background: linear-gradient(to bottom, rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0));
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  .site-header.scrolled::before {
    opacity: 1;
  }
  .brand {
    font-style: italic;
    font-weight: 500;
    font-size: 1.7rem;
    color: #f3f4f6;
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.5);
  }
  .nav {
    display: flex;
    flex-wrap: nowrap;
    justify-content: center;
    align-items: center;
    gap: 1.5rem;
    max-width: 100%;
  }
  .nav-link {
    color: #e5e7eb;
    font-size: 1rem;
    opacity: 0.85;
    white-space: nowrap;
    transition: opacity 0.15s ease, transform 0.15s ease;
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.5);
  }
  .nav-link:hover { opacity: 1; transform: scale(1.08); }
  .nav-link.active { opacity: 1; text-decoration: underline; text-underline-offset: 6px; }

  /* "More" overflow dropdown */
  .more-wrap { position: relative; display: inline-flex; }
  .more-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }
  .more-caret { width: 0.8rem; height: 0.8rem; transition: transform 0.15s ease; }
  .more-wrap.open .more-caret { transform: rotate(180deg); }
  .more-menu {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(4px);
    display: flex;
    flex-direction: column;
    min-width: 9rem;
    margin-top: 0.5rem;
    padding: 0.4rem;
    border-radius: 0.6rem;
    background: rgba(6, 8, 12, 0.96);
    border: 1px solid rgba(255, 255, 255, 0.12);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.5);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.15s ease, transform 0.15s ease;
    z-index: 50;
  }
  .more-wrap.open .more-menu { opacity: 1; visibility: visible; }
  .more-menu .nav-link {
    width: 100%;
    padding: 0.5rem 0.9rem;
    text-align: center;
    border-radius: 0.4rem;
    text-shadow: none;
  }
  .more-menu .nav-link:hover { background: rgba(255, 255, 255, 0.08); transform: none; }
</style>

<script is:inline>
  // Fade the scrim in once scrolled. Idempotent across ClientRouter navigations.
  function initHeaderScrim() {
    const header = document.getElementById('site-header')
    if (!header) return
    const onScroll = () => header.classList.toggle('scrolled', window.scrollY > 8)
    if (window.__headerScroll) window.removeEventListener('scroll', window.__headerScroll)
    window.__headerScroll = onScroll
    window.addEventListener('scroll', onScroll, { passive: true })
    onScroll()
  }
  document.addEventListener('astro:page-load', initHeaderScrim)

  // Priority+ nav: keep links inline; move the ones that don't fit into "More".
  function initNavOverflow() {
    if (window.__navResize) {
      window.removeEventListener('resize', window.__navResize)
      window.__navResize = null
    }
    const nav = document.getElementById('primary-nav')
    if (!nav) return
    const moreWrap = document.getElementById('nav-more')
    const moreMenu = document.getElementById('nav-more-menu')
    const moreBtn = document.getElementById('nav-more-btn')
    if (!moreWrap || !moreMenu || !moreBtn) return

    // Capture the server-rendered order (moreWrap is last).
    const original = Array.from(nav.children)
    const closeMore = () => {
      moreWrap.classList.remove('open')
      moreBtn.setAttribute('aria-expanded', 'false')
    }
    const reset = () => {
      original.forEach((el) => {
        if (el.classList) el.classList.remove('more-item')
        nav.appendChild(el)
      })
      moreWrap.hidden = true
      closeMore()
    }
    const fits = () => nav.scrollWidth <= nav.clientWidth + 1
    const layout = () => {
      reset()
      if (fits()) return
      moreWrap.hidden = false
      let guard = 0
      while (!fits() && guard++ < 20) {
        // Move the last plain inline link (not the Posts dropdown) into More.
        const links = Array.from(nav.children).filter(
          (c) => c.classList && c.classList.contains('nav-link')
        )
        const last = links[links.length - 1]
        if (!last) break
        last.classList.add('more-item')
        moreMenu.insertBefore(last, moreMenu.firstChild)
      }
    }
    layout()
    window.__navResize = () => layout()
    window.addEventListener('resize', window.__navResize)

    if (!moreBtn.dataset.bound) {
      moreBtn.dataset.bound = '1'
      moreBtn.addEventListener('click', (e) => {
        e.stopPropagation()
        const open = moreWrap.classList.toggle('open')
        moreBtn.setAttribute('aria-expanded', open ? 'true' : 'false')
      })
      moreMenu.addEventListener('click', (e) => {
        if (e.target.closest('a')) closeMore()
      })
    }
    if (!window.__navMoreDoc) {
      window.__navMoreDoc = true
      document.addEventListener('click', (e) => {
        const w = document.getElementById('nav-more')
        if (w && w.classList.contains('open') && !w.contains(e.target)) {
          w.classList.remove('open')
          document.getElementById('nav-more-btn')?.setAttribute('aria-expanded', 'false')
        }
      })
      document.addEventListener('keydown', (e) => {
        if (e.key !== 'Escape') return
        document.getElementById('nav-more')?.classList.remove('open')
      })
    }
  }
  document.addEventListener('astro:page-load', initNavOverflow)
</script>
