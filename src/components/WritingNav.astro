---
import { Icon } from 'astro-icon/components'

interface Props {
  active?: boolean
}
const { active = false } = Astro.props
---

<!-- Split control: "Writing" text links to /writing; the caret toggles the
     Blog/TIL menu. Plain Astro + a tiny vanilla toggle (no React island). -->
<span class="nav-writing" data-active={active ? 'true' : undefined}>
  <a href="/writing" class="nav-writing-link">Writing</a>
  <button
    type="button"
    class="nav-caret"
    aria-label="Open writing menu"
    aria-haspopup="true"
    aria-expanded="false"
  >
    <Icon name="ph:caret-down" />
  </button>
  <div class="dd-menu" role="menu">
    <a href="/blog" role="menuitem" class="dd-item">Blog</a>
    <a href="/til" role="menuitem" class="dd-item">TIL</a>
  </div>
</span>

<style>
  .nav-writing {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }
  .nav-writing-link {
    font-size: 1rem;
    color: #e5e7eb;
    opacity: 0.85;
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.5);
    transition: opacity 0.15s ease, transform 0.15s ease;
  }
  .nav-writing-link:hover { opacity: 1; transform: scale(1.08); }
  .nav-writing[data-active='true'] .nav-writing-link {
    opacity: 1;
    text-decoration: underline;
    text-underline-offset: 6px;
  }
  .nav-caret {
    display: inline-flex;
    align-items: center;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.15rem;
    color: #e5e7eb;
    opacity: 0.85;
    transition: opacity 0.15s ease;
  }
  .nav-caret:hover { opacity: 1; }
  .nav-caret :global(svg) {
    width: 0.8rem;
    height: 0.8rem;
    filter: drop-shadow(0 1px 6px rgba(0, 0, 0, 0.5));
    transition: transform 0.15s ease;
  }
  .nav-writing.open .nav-caret :global(svg) { transform: rotate(180deg); }

  .dd-menu {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(4px);
    display: flex;
    flex-direction: column;
    min-width: 8.5rem;
    margin-top: 0.5rem;
    padding: 0.4rem;
    border-radius: 0.6rem;
    background: rgba(10, 12, 16, 0.72);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.14);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.4);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.15s ease, transform 0.15s ease;
  }
  .nav-writing.open .dd-menu {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(8px);
  }
  .dd-item {
    color: #e5e7eb;
    padding: 0.45rem 0.7rem;
    border-radius: 0.4rem;
    font-size: 0.95rem;
    opacity: 0.85;
    text-align: center;
    transition: background 0.15s ease, opacity 0.15s ease;
  }
  .dd-item:hover { opacity: 1; background: rgba(255, 255, 255, 0.1); }
</style>

<script is:inline>
  function initWritingDD() {
    const root = document.querySelector('.nav-writing')
    if (root) {
      const btn = root.querySelector('.nav-caret')
      if (btn && !btn.dataset.bound) {
        btn.dataset.bound = '1'
        btn.addEventListener('click', (e) => {
          e.stopPropagation()
          const open = root.classList.toggle('open')
          btn.setAttribute('aria-expanded', String(open))
        })
      }
    }
    // Document-level close handlers bound once (survives ClientRouter navs).
    if (!window.__writingDDDoc) {
      window.__writingDDDoc = true
      const closeAll = () =>
        document.querySelectorAll('.nav-writing.open').forEach((r) => {
          r.classList.remove('open')
          r.querySelector('.nav-caret')?.setAttribute('aria-expanded', 'false')
        })
      document.addEventListener('click', (e) => {
        const open = document.querySelector('.nav-writing.open')
        if (open && !open.contains(e.target)) closeAll()
      })
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeAll()
      })
    }
  }
  document.addEventListener('astro:page-load', initWritingDD)
</script>
