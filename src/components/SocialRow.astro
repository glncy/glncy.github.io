---
import { Icon } from 'astro-icon/components'
import settings from '../data/settings.json'

const email = settings.contact.email
const socials = settings.socials ?? []

const links = [
  ...socials.map((s) => ({ name: s.label, href: s.url, icon: s.icon, external: true })),
  email && { name: 'Email', href: `mailto:${email}`, icon: 'ph:envelope-simple', external: false },
].filter(Boolean) as { name: string; href: string; icon: string; external: boolean }[]
---

<div class="social-row">
  {links.map((l) => (
    <a
      href={l.href}
      aria-label={l.name}
      {...(l.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
    >
      <Icon name={l.icon} />
    </a>
  ))}
</div>

<style>
  .social-row {
    display: flex;
    gap: 1.4rem;
    justify-content: center;
    align-items: center;
  }
  .social-row a {
    color: #ffffff;
    line-height: 0;
    transition: transform 0.15s ease, color 0.15s ease;
    /* drop-shadow keeps icons legible over the bright/busy video */
    filter: drop-shadow(0 1px 6px rgba(0, 0, 0, 0.7));
  }
  .social-row a:hover {
    transform: translateY(-2px) scale(1.15);
  }
  .social-row :global(svg) {
    width: 1.7rem;
    height: 1.7rem;
  }
</style>
